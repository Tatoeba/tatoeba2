msgstr "אפשר להציע עזרה נוספת?"

#: github.com/Tatoeba/tatoeba2/tree/dev/templates/Pages/help.php#L38
msgid "You can check out the <a href=\"{}\">FAQ</a>."
msgstr "אפשר לעיין <a href=\"{}\">בשאלות הנפוצות</a>."

#: github.com/Tatoeba/tatoeba2/tree/dev/templates/Pages/help.php#L46
